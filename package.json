{
  "name": "prompt-cabinet",
  "version": "0.1.0-beta.1",
  "description": "A local-first desktop library for collecting, organizing, and reusing prompts.",
  "author": "Jingyi Bi",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5177 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "desktop:dev": "npm run build && electron .",
    "desktop:package": "npm run build && electron-builder --config.electronDist=node_modules/electron/dist",
    "desktop:package:mac": "pnpm run build && electron-builder --mac dmg --arm64 --publish never --config.electronDist=node_modules/electron/dist",
    "desktop:unpacked": "npm run build && electron-builder --dir --config.electronDist=node_modules/electron/dist --config.directories.output=release-share",
    "desktop:portable": "npm run build && electron-builder --win portable --config.electronDist=node_modules/electron/dist --config.directories.output=release-share"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.142.0",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.promptcabinet.app",
    "productName": "Prompt Cabinet",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "asarUnpack": [
      "node_modules/@openai/codex*/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "identity": "-",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "artifactName": "Prompt-Cabinet-${version}-mac-${arch}.${ext}"
    },
    "dmg": {
      "sign": false,
      "title": "Prompt Cabinet ${version}"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
