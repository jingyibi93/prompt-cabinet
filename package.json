{
  "name": "prompt-cabinet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5177 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "desktop:dev": "npm run build && electron .",
    "desktop:package": "npm run build && electron-builder",
    "desktop:portable": "npm run build && electron-builder --win portable --config.directories.output=release-portable"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.142.0",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.promptcabinet.app",
    "productName": "Prompt Cabinet",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
